{
  "model": "sonnet",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code finished responding\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code is waiting for your input\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "planning-with-files@planning-with-files": true,
    "atlassian@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "planning-with-files": {
      "source": {
        "source": "github",
        "repo": "OthmanAdi/planning-with-files"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "editorMode": "vim",
  "preferredNotifChannel": "ghostty",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
